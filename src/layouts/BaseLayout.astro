---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  hreflangUrls?: { en: string; de: string; fr: string };
  schemaType?: 'homepage' | 'casestudy' | 'service';
}

const {
  title,
  description,
  lang = 'en',
  canonicalUrl,
  ogTitle,
  ogDescription,
  ogImage = 'https://houseofagile.com/assets/images/og-preview.png',
  hreflangUrls,
  schemaType,
} = Astro.props;

const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
const ogLocaleMap: Record<string, string> = { en: 'en_US', de: 'de_DE', fr: 'fr_FR' };
const ogLocale = ogLocaleMap[lang] || 'en_US';
---

<!doctype html>
<html lang={lang} dir="ltr">
<head>
  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-M66S2HG2');</script>
  <!-- End Google Tag Manager -->
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CZ92MVYJE8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-CZ92MVYJE8');
  </script>

  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.ico" sizes="48x48" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="House of Agile" />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:title" content={resolvedOgTitle} />
  <meta property="og:description" content={resolvedOgDescription} />
  <meta property="og:type" content="website" />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImage} />

  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

  {hreflangUrls && (
    <>
      <link rel="alternate" hreflang="en" href={hreflangUrls.en} />
      <link rel="alternate" hreflang="de" href={hreflangUrls.de} />
      <link rel="alternate" hreflang="fr" href={hreflangUrls.fr} />
      <link rel="alternate" hreflang="x-default" href={hreflangUrls.en} />
    </>
  )}

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" referrerpolicy="no-referrer" />

  {schemaType === 'homepage' && (
    <>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "House of Agile",
        "url": "https://houseofagile.com",
        "logo": "https://houseofagile.com/assets/hoa-logo-full.png",
        "description": "Senior technology consultancy — fractional CTO, AI workflow automation, and custom business platforms for SMEs across Europe",
        "areaServed": ["France", "Switzerland", "Germany"],
        "founder": { "@type": "Person", "name": "Jean-Christophe Meillaud" },
        "email": "mailto:jc@houseofagile.com"
      })} />
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "House of Agile",
        "image": "https://houseofagile.com/assets/hoa-logo-full.png",
        "url": "https://houseofagile.com",
        "email": "jc@houseofagile.com",
        "description": "Senior technology consultancy helping businesses modernize operations, automate workflows, and build scalable platforms.",
        "priceRange": "€€€",
        "areaServed": [
          { "@type": "Country", "name": "Switzerland" },
          { "@type": "Country", "name": "Germany" }
        ],
        "serviceType": ["Fractional CTO", "AI Workflow Automation", "Custom Business Platforms", "Legacy Modernization", "Product Delivery Leadership"],
        "founder": { "@type": "Person", "name": "Jean-Christophe Meillaud", "jobTitle": "Founder & Lead Consultant" },
        "sameAs": ["https://www.linkedin.com/company/house-of-agile"]
      })} />
    </>
  )}
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M66S2HG2"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

  <slot />
</body>
</html>
