---
import { getCollection, render } from 'astro:content';
import CaseStudyPage from '../../../components/CaseStudyPage.astro';

export async function getStaticPaths() {
  const entries = await getCollection('caseStudies', ({ id }) => id.startsWith('de/'));
  return entries.map((entry) => ({
    params: { slug: entry.id.replace('de/', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<CaseStudyPage entry={entry} lang="de" ContentComponent={Content} />
