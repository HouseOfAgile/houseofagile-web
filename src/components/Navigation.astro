---
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';
import { getLocalePath } from '../i18n/utils';

interface Props {
  lang: string;
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;
const t = useTranslations(lang as Lang);

const pathname = Astro.url.pathname;
const homePath = getLocalePath(lang as Lang);
const isHomepage = pathname === homePath || pathname === homePath.replace(/\/$/, '');
const anchor = (hash: string) => isHomepage ? hash : `${homePath}${hash}`;

const navLinks = [
  { key: 'nav.services' as const, href: anchor('#services') },
  { key: 'nav.caseStudies' as const, href: anchor('#case-studies') },
  { key: 'nav.about' as const, href: getLocalePath(lang as Lang, 'about') },
  { key: 'nav.contact' as const, href: anchor('#contact') },
];

let basePath = pathname;
if (basePath.startsWith('/de/')) basePath = basePath.slice(4);
else if (basePath.startsWith('/fr/')) basePath = basePath.slice(4);
else if (basePath.startsWith('/')) basePath = basePath.slice(1);
if (basePath.endsWith('/')) basePath = basePath.slice(0, -1);

const langLinks = [
  { code: 'en', label: 'EN', href: basePath ? `/${basePath}` : '/' },
  { code: 'de', label: 'DE', href: basePath ? `/de/${basePath}` : '/de/' },
  { code: 'fr', label: 'FR', href: basePath ? `/fr/${basePath}` : '/fr/' },
];
---

<nav class="nav-glass sticky top-0 z-50 border-b border-hoa-100/50" id="main-nav">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <!-- Logo + Brand -->
    <a href={getLocalePath(lang as Lang)} class="flex items-center gap-2.5 flex-shrink-0 group">
      <div class="relative">
        <img src="/assets/hoa-logo-full.png" alt="House of Agile" width="36" height="36" class="w-9 h-9 transition-transform duration-300 group-hover:scale-105" />
        <div class="absolute inset-0 rounded-full bg-green-500/0 group-hover:bg-green-500/10 transition-colors duration-300"></div>
      </div>
      <span class="nav-brand hidden sm:inline">House of Agile</span>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="nav-link text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors px-3 py-2 rounded-lg hover:bg-gray-50/80">
          {t(link.key)}
        </a>
      ))}
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-2">
      <!-- Language switcher - inline pills -->
      <div class="flex items-center rounded-full bg-gray-100/80 p-0.5">
        {langLinks.map((l) => (
          <a
            href={l.href}
            class={`px-2.5 py-1 text-xs font-semibold rounded-full transition-all duration-200 ${
              lang === l.code
                ? 'bg-white text-gray-900 shadow-sm'
                : 'text-gray-500 hover:text-gray-700'
            }`}
          >
            {l.label}
          </a>
        ))}
      </div>

      <!-- CTA button -->
      <a href={anchor('#contact')} class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-full bg-gray-900 text-white hover:bg-gray-800 transition-all duration-200 shadow-sm hover:shadow-md">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {t('nav.ctaShort')}
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-full hover:bg-gray-100 transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="hamburger-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-5 h-5 text-gray-700 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="close-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100/80 bg-white/98 backdrop-blur-xl">
    <div class="max-w-6xl mx-auto px-4 py-5 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="text-base font-medium text-gray-700 hover:text-hoa-600 py-3 px-3 rounded-xl hover:bg-gray-50 transition-colors mobile-nav-link">
          {t(link.key)}
        </a>
      ))}
      <!-- Mobile language pills -->
      <div class="flex items-center gap-2 px-3 py-3 mt-2 border-t border-gray-100">
        {langLinks.map((l) => (
          <a
            href={l.href}
            class={`px-4 py-2 rounded-full text-sm font-semibold transition-colors ${
              lang === l.code
                ? 'bg-gray-900 text-white'
                : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
            }`}
          >
            {l.label}
          </a>
        ))}
      </div>
      <a href={anchor('#contact')} class="mt-2 flex items-center justify-center gap-2 py-3 px-6 rounded-full bg-gray-900 text-white font-semibold text-sm hover:bg-gray-800 transition-colors mobile-nav-link">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {t('nav.ctaShort')}
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle with icon swap
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });

  // Scroll effect - add .scrolled class
  const nav = document.getElementById('main-nav');
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (window.scrollY > 20) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
</script>
